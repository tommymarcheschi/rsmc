# PokéVault Environment Variables
# Copy this file to .env and fill in your values

# Supabase (Required)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Pokémon TCG API (Optional — increases rate limit from 1000 to 20000 req/day)
POKEMON_TCG_API_KEY=your-api-key-here

# PokeTrace (Required for pricing features)
POKETRACE_API_KEY=your-api-key-here

# PokemonPriceTracker (Required for grading features)
PRICE_TRACKER_API_KEY=your-api-key-here
